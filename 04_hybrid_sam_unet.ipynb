    "def dice_score(\n",
    "    preds,\n",
    "    targets,\n",
    "    smooth=1e-6\n",
    "):\n",
    "\n",
    "    preds = (\n",
    "        preds > 0.5\n",
    "    ).float()\n",
    "\n",
    "    intersection = (\n",
    "        preds * targets\n",
    "    ).sum()\n",
    "\n",
    "    return (\n",
    "        2 * intersection + smooth\n",
    "    ) / (\n",
    "        preds.sum()\n",
    "        + targets.sum()\n",
    "        + smooth\n",
    "    )"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "id": "ccc7b693",
   "metadata": {},
   "outputs": [],
   "source": [
    "def iou_score(\n",
    "    preds,\n",
    "    targets,\n",
    "    smooth=1e-6\n",
    "):\n",
    "\n",
    "    preds = (\n",
    "        preds > 0.5\n",
    "    ).float()\n",
    "\n",
    "    intersection = (\n",
    "        preds * targets\n",
    "    ).sum()\n",
    "\n",
    "    union = (\n",
    "        preds + targets\n",
    "    ).sum() - intersection\n",
    "\n",
    "    return (\n",
    "        intersection + smooth\n",
    "    ) / (\n",
    "        union + smooth\n",
    "    )"
   ]
  },
  {
   "cell_type": "code",
