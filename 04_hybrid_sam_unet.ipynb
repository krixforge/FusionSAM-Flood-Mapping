    "def validate_one_epoch(\n",
    "    model,\n",
    "    loader,\n",
    "    criterion,\n",
    "    device\n",
    "):\n",
    "\n",
    "    model.eval()\n",
    "\n",
    "    running_loss = 0\n",
    "    running_dice = 0\n",
    "    running_iou = 0\n",
    "\n",
    "    with torch.no_grad():\n",
    "\n",
    "        for images, masks, sam_features in loader:\n",
    "\n",
    "            images = images.to(device)\n",
    "\n",
    "            masks = masks.to(device)\n",
    "\n",
    "            sam_features = sam_features.to(device)\n",
    "\n",
    "            outputs = model(\n",
    "                images,\n",
    "                sam_features\n",
    "            )\n",
    "\n",
    "            loss = criterion(\n",
    "                outputs,\n",
    "                masks\n",
    "            )\n",
