   "source": [
    "class HybridSAMUNet(nn.Module):\n",
    "\n",
    "    def __init__(\n",
    "        self,\n",
    "        in_channels=3,\n",
    "        sam_channels=256\n",
    "    ):\n",
    "\n",
    "        super().__init__()\n",
    "\n",
    "        # Encoder\n",
    "\n",
    "        self.e1 = DoubleConv(\n",
    "            in_channels,\n",
    "            64\n",
    "        )\n",
    "\n",
    "        self.pool1 = nn.MaxPool2d(2)\n",
    "\n",
    "        self.e2 = DoubleConv(\n",
    "            64,\n",
    "            128\n",
    "        )\n",
    "\n",
    "        self.pool2 = nn.MaxPool2d(2)\n",
    "\n",
    "        # Fusion Bottleneck\n",
    "\n",
    "        self.bottleneck = DoubleConv(\n",
    "            128 + sam_channels,\n",
    "            256\n",
    "        )\n",
    "\n",
    "        # Decoder\n",
    "\n",
    "        self.up1 = nn.ConvTranspose2d(\n",
    "            256,\n",
    "            128,\n",
    "            kernel_size=2,\n",
    "            stride=2\n",
    "        )\n",
    "\n",
    "        self.d1 = DoubleConv(\n",
    "            128 + 128,\n",
    "            128\n",
    "        )\n",
    "\n",
    "        self.up2 = nn.ConvTranspose2d(\n",
    "            128,\n",
    "            64,\n",
    "            kernel_size=2,\n",
    "            stride=2\n",
    "        )\n",
    "\n",
    "        self.d2 = DoubleConv(\n",
    "            64 + 64,\n",
    "            64\n",
    "        )\n",
    "\n",
    "        self.out = nn.Conv2d(\n",
    "            64,\n",
    "            1,\n",
    "            kernel_size=1\n",
    "        )\n",
    "\n",
    "    def forward(\n",
    "        self,\n",
    "        x,\n",
    "        sam_feature\n",
    "    ):\n",
    "\n",
    "        e1 = self.e1(x)\n",
    "\n",
    "        p1 = self.pool1(e1)\n",
    "\n",
    "        e2 = self.e2(p1)\n",
    "\n",
    "        p2 = self.pool2(e2)\n",
    "\n",
    "        sam_resized = F.interpolate(\n",
    "            sam_feature,\n",
    "            size=p2.shape[2:],\n",
    "            mode=\"bilinear\",\n",
    "            align_corners=False\n",
    "        )\n",
    "\n",
    "        fusion = torch.cat(\n",
    "            [\n",
    "                p2,\n",
    "                sam_resized\n",
    "            ],\n",
    "            dim=1\n",
    "        )\n",
    "\n",
    "        b = self.bottleneck(\n",
    "            fusion\n",
    "        )\n",
    "\n",
    "        u1 = self.up1(b)\n",
    "\n",
    "        u1 = torch.cat(\n",
    "            [\n",
    "                u1,\n",
    "                e2\n",
    "            ],\n",
    "            dim=1\n",
    "        )\n",
    "\n",
    "        d1 = self.d1(u1)\n",
    "\n",
    "        u2 = self.up2(d1)\n",
    "\n",
    "        u2 = torch.cat(\n",
    "            [\n",
    "                u2,\n",
    "                e1\n",
    "            ],\n",
    "            dim=1\n",
    "        )\n",
    "\n",
    "        d2 = self.d2(u2)\n",
    "\n",
    "        logits = self.out(d2)\n",
    "\n",
    "        return logits"
   ]
  },
