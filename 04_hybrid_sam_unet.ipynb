    "class DoubleConv(nn.Module):\n",
    "\n",
    "    def __init__(\n",
    "        self,\n",
    "        in_channels,\n",
    "        out_channels\n",
    "    ):\n",
    "\n",
    "        super().__init__()\n",
    "\n",
    "        self.block = nn.Sequential(\n",
    "\n",
    "            nn.Conv2d(\n",
    "                in_channels,\n",
    "                out_channels,\n",
    "                kernel_size=3,\n",
    "                padding=1,\n",
    "                bias=False\n",
    "            ),\n",
    "\n",
    "            nn.BatchNorm2d(\n",
    "                out_channels\n",
    "            ),\n",
    "\n",
    "            nn.ReLU(\n",
    "                inplace=True\n",
    "            ),\n",
    "\n",
    "            nn.Conv2d(\n",
    "                out_channels,\n",
    "                out_channels,\n",
    "                kernel_size=3,\n",
    "                padding=1,\n",
    "                bias=False\n",
    "            ),\n",
    "\n",
    "            nn.BatchNorm2d(\n",
    "                out_channels\n",
    "            ),\n",
    "\n",
    "            nn.ReLU(\n",
    "                inplace=True\n",
    "            )\n",
    "        )\n",
    "\n",
    "    def forward(\n",
    "        self,\n",
    "        x\n",
    "    ):\n",
    "\n",
    "        return self.block(x)"
   ]
  },
