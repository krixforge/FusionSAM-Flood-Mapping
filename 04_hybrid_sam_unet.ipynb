   "id": "8c04f79d",
   "metadata": {},
   "outputs": [],
   "source": [
    "def train_one_epoch(\n",
    "    model,\n",
    "    loader,\n",
    "    optimizer,\n",
    "    criterion,\n",
    "    device\n",
    "):\n",
    "\n",
    "    model.train()\n",
    "\n",
    "    running_loss = 0\n",
    "    running_dice = 0\n",
    "    running_iou = 0\n",
    "\n",
    "    for images, masks, sam_features in loader:\n",
    "\n",
    "        images = images.to(device)\n",
    "\n",
    "        masks = masks.to(device)\n",
    "\n",
    "        sam_features = sam_features.to(device)\n",
    "\n",
    "        optimizer.zero_grad()\n",
    "\n",
    "        outputs = model(\n",
    "            images,\n",
    "            sam_features\n",
    "        )\n",
    "\n",
    "        loss = criterion(\n",
    "            outputs,\n",
    "            masks\n",
    "        )\n",
    "\n",
    "        loss.backward()\n",
    "\n",
    "        optimizer.step()\n",
    "\n",
    "        probs = torch.sigmoid(\n",
    "            outputs\n",
    "        )\n",
    "\n",
    "        running_loss += loss.item()\n",
    "\n",
    "        running_dice += dice_score(\n",
    "            probs,\n",
    "            masks\n",
    "        ).item()\n",
    "\n",
    "        running_iou += iou_score(\n",
    "            probs,\n",
    "            masks\n",
    "        ).item()\n",
    "\n",
    "    return (\n",
    "\n",
    "        running_loss / len(loader),\n",
    "\n",
    "        running_dice / len(loader),\n",
    "\n",
    "        running_iou / len(loader)\n",
    "\n",
    "    )"
   ]
  },
