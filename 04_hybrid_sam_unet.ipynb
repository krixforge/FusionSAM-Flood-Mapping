    "\n",
    "    background_pixels += (\n",
    "        mask.numel() - mask.sum().item()\n",
    "    )\n",
    "\n",
    "print(\"Background:\", background_pixels)\n",
    "print(\"Water:\", water_pixels)"
   ]
